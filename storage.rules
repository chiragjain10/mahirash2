rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@perfume.com';
    }
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}